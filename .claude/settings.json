{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(npx:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(prisma:*)",
      "Bash(echo:*)",
      "Bash(touch:*)",
      "Bash(rm:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(export:*)",
      "Bash(NVM_DIR=*)",
      "TodoRead",
      "TodoWrite"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "NVM_DIR": "$HOME/.nvm"
  },
  "teammateMode": "tmux"
}